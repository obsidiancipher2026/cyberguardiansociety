{
  "name": "cyberguardians-society",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n FE,BE -c cyan,yellow \"npm run dev:fe\" \"npm run dev:be\"",
    "dev:fe": "cd frontend && npm run dev",
    "dev:be": "cd backend && npm run dev",
    "build": "cd frontend && npm run build && cd ../backend && npm run build",
    "start": "concurrently \"npm run start:fe\" \"npm run start:be\"",
    "start:fe": "cd frontend && npm start",
    "start:be": "cd backend && npm start"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
