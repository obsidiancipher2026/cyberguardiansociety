<%# CGS Team Card — EJS Partial (unified card, Option A overlay) %>
<%
var tier = locals.tier || 'general';
var member = locals.member || {};
var initials = member.name ? member.name.split(' ').map(function(n) { return n[0]; }).join('') : '';
var socialKeys = member.socials ? Object.keys(member.socials) : [];
var hasSocials = socialKeys.length > 0;
var photoSize = tier === 'leadership' ? 32 : 24;
var socialPaths = typeof SOCIAL_PATHS !== 'undefined' ? SOCIAL_PATHS : {};
%>

<div class="team-card <%= tier %>" role="article" aria-label="<%= member.name %> — <%= member.title %>" tabindex="0">
  <div class="team-card-inner">
    <div class="team-card-photo">
      <div class="team-card-photo-ring"></div>
      <div class="team-card-photo-placeholder">
        <span style="font-size:<%= photoSize %>px;"><%= initials %></span>
      </div>

      <div class="team-card-overlay">
        <% if (member.skills && member.skills.length > 0) { %>
          <div class="team-card-skills">
            <% member.skills.slice(0, 3).forEach(function(skill) { %>
              <span class="team-skill-tag"><%= skill %></span>
            <% }); %>
          </div>
        <% } %>
        <% if (hasSocials) { %>
          <div class="team-card-socials">
            <% socialKeys.forEach(function(platform) { %>
              <a href="<%= member.socials[platform] %>" target="_blank" rel="noopener noreferrer" class="team-social-link" aria-label="<%= member.name %> on <%= platform %>">
                <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14" xmlns="http://www.w3.org/2000/svg">
                  <% if (socialPaths[platform]) { %>
                    <path d="<%= socialPaths[platform] %>" />
                  <% } %>
                </svg>
              </a>
            <% }); %>
          </div>
        <% } %>
      </div>
    </div>

    <div class="team-card-content">
      <div class="team-role-badge">
        <% if (tier === 'leadership') { %>
          <span class="leadership-star">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </span>
        <% } %>
        <%= member.roleBadge %>
      </div>

      <h3 class="team-card-name"><%= member.name %></h3>

      <% if (member.specialty) { %>
        <p class="team-card-specialty"><%= member.specialty %></p>
      <% } %>
    </div>
  </div>
</div>
