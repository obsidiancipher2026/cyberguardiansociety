<%# CGS Team Card — EJS Partial %>
<%
var tier = locals.tier || 'general';
var member = locals.member || {};
var initials = member.name ? member.name.split(' ').map(function(n) { return n[0]; }).join('') : '';
var socialKeys = member.socials ? Object.keys(member.socials) : [];
var hasSocials = socialKeys.length > 0;
var socialPaths = typeof SOCIAL_PATHS !== 'undefined' ? SOCIAL_PATHS : {};
%>

<div class="team-card <%= tier %>" role="article" aria-label="<%= member.name %> — <%= member.title %>">
  <div class="team-card-border-glow <%= tier %>" aria-hidden="true"></div>

  <div class="team-card-content">
    <div class="team-card-photo <%= tier %>">
      <div class="team-card-photo-ring <%= tier %>" aria-hidden="true"></div>
      <% if (member.photo) { %>
        <img src="<%= member.photo %>" alt="<%= member.name %> — <%= member.title %>" loading="lazy" />
      <% } else { %>
        <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#0A0A0F;">
          <span style="font-size:<%= tier === 'leadership' ? '32px' : '24px' %>;font-weight:700;color:rgba(255,255,255,0.1);">
            <%= initials %>
          </span>
        </div>
      <% } %>
    </div>

    <div class="team-role-badge <%= tier %>">
      <% if (tier === 'leadership') { %>
        <span class="leadership-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        </span>
      <% } %>
      <%= member.roleBadge %>
    </div>

    <h3 class="team-card-name <%= tier %>"><%= member.name %></h3>
    <% if (member.specialty) { %>
      <p class="team-card-specialty"><%= member.specialty %></p>
    <% } %>

    <% if (member.bio) { %>
      <p class="team-card-bio"><%= member.bio %></p>
    <% } %>

    <% if (member.skills && member.skills.length > 0) { %>
      <div class="team-card-skills">
        <% member.skills.slice(0, 4).forEach(function(skill) { %>
          <span class="team-skill-tag"><%= skill %></span>
        <% }); %>
      </div>
    <% } %>

    <% if (hasSocials) { %>
      <div class="team-card-socials">
        <% socialKeys.forEach(function(platform) { %>
          <a href="<%= member.socials[platform] %>" target="_blank" rel="noopener noreferrer" class="team-social-link" aria-label="<%= member.name %> on <%= platform %>">
            <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" xmlns="http://www.w3.org/2000/svg">
              <% if (socialPaths[platform]) { %>
                <path d="<%= socialPaths[platform] %>" />
              <% } %>
            </svg>
          </a>
        <% }); %>
      </div>
    <% } %>
  </div>
</div>
