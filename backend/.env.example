# ── Server ──
NODE_ENV=development
PORT=5000

# ── Database ──
# SQLite (local dev)
SQLITE_PATH=./data/cyberguardians.sqlite
# PostgreSQL (production — set this to switch to Prisma)
DATABASE_URL=postgresql://user:password@host:5432/cyberguardians?sslmode=require

# ── JWT ──
JWT_SECRET=<generate-a-256-bit-random-secret>
JWT_REFRESH_SECRET=<generate-another-256-bit-random-secret>
JWT_EXPIRY=10m
REFRESH_TOKEN_EXPIRY=7d

# ── Admin ──
ADMIN_EMAIL=admin@cyberguardians.com
ADMIN_PASSWORD=<strong-password-min-12-chars>

# ── Admin Panel ──
ADMIN_PANEL_SECRET=<random-unguessable-path-suffix>

# ── Frontend ──
FRONTEND_URL=http://localhost:3000

# ── SMTP (optional) ──
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=true
SMTP_FROM=

# ── Other ──
BCRYPT_SALT_ROUNDS=12
